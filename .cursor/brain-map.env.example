# Copy to .cursor/brain-map.env and load before running build_brain_map.py, or paste into your shell.
# .cursor/brain-map.env is listed in software .gitignore (do not commit local paths).
#
# Windows (PowerShell), from software repo root:
#   Get-Content .cursor/brain-map.env | ForEach-Object { if ($_ -match '^\s*#' -or $_ -eq '') { } else { iex "`$env:$($_.Split('=',2)[0])='$($_.Split('=',2)[1])'" } }  # fragile; prefer manual $env: lines below

# Merge multiple repos' .cursor/state (semicolon on Windows)
CURSOR_STATE_DIRS=D:\openharness\.cursor\state;D:\software\.cursor\state
CURSOR_STATE_DIR_LABELS=openharness,software

# Include markdown docs as vault nodes/edges (e.g. openharness/docs)
BRAIN_MAP_VAULT_ROOTS=D:\openharness\docs
BRAIN_MAP_VAULT_LABELS=openharness_docs

# Optional: override output path (default with vault roots: OpenGrimoire/public/brain-map-graph.local.json)
# BRAIN_MAP_OUTPUT=
