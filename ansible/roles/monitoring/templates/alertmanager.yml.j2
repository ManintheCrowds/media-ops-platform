global:
  resolve_timeout: 5m
  smtp_smarthost: '{{ smtp_host }}:{{ smtp_port | default(587) }}'
  smtp_from: '{{ smtp_from }}'
  smtp_auth_username: '{{ smtp_username }}'
  smtp_auth_password: '{{ smtp_password }}'
  smtp_require_tls: {{ smtp_require_tls | default(true) }}

route:
  group_by: ['alertname', 'cluster', 'service']
  group_wait: 10s
  group_interval: 10s
  repeat_interval: 12h
  receiver: 'default'
  routes:
    - match:
        severity: critical
      receiver: 'critical'
      continue: true
    - match:
        severity: warning
      receiver: 'warning'

receivers:
  - name: 'default'
    email_configs:
      - to: '{{ alert_email_to }}'
        headers:
          Subject: 'Platform Alert: {{ "{{ .GroupLabels.alertname }}" }}'
        html: '{{ alert_email_template | default("") }}'

  - name: 'critical'
    email_configs:
      - to: '{{ alert_email_critical_to | default(alert_email_to) }}'
        headers:
          Subject: 'CRITICAL: Platform Alert - {{ "{{ .GroupLabels.alertname }}" }}'
        html: '{{ alert_email_template | default("") }}'

  - name: 'warning'
    email_configs:
      - to: '{{ alert_email_to }}'
        headers:
          Subject: 'WARNING: Platform Alert - {{ "{{ .GroupLabels.alertname }}" }}'
        html: '{{ alert_email_template | default("") }}'

inhibit_rules:
  - source_match:
      severity: 'critical'
    target_match:
      severity: 'warning'
    equal: ['alertname', 'cluster', 'service']
