# Pi Client Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

device:
  device_id: "{{ device_id }}"
  device_name: "{{ device_name }}"

api:
  base_url: "{{ pi_client_config.api.base_url }}"
  auth_token: "{{ pi_api_token | default('') }}"
  timeout: {{ pi_client_config.api.timeout | default(30) }}

cache:
  directory: "{{ pi_client_data_path }}/cache"
  max_size_mb: {{ pi_client_config.cache.max_size_mb | default(5000) }}
  ttl_hours: {{ pi_client_config.cache.ttl_hours | default(168) }}

display:
  port: {{ pi_client_config.display.port | default(8080) }}
  rotation: "{{ pi_client_config.display.rotation | default('landscape') }}"
  fullscreen: {{ pi_client_config.display.fullscreen | default(true) }}
  mode: "{{ pi_client_config.display.mode | default('kiosk') }}"

hardware:
  gpio_enabled: {{ pi_client_config.hardware.gpio_enabled | default(true) }}
  camera_enabled: {{ pi_client_config.hardware.camera_enabled | default(false) }}
  audio_enabled: {{ pi_client_config.hardware.audio_enabled | default(true) }}

security:
  cert_path: "{{ pi_certificate_path }}"
  key_path: "{{ pi_certificate_key_path }}"
  ca_path: "{{ pi_certificate_ca | default('') }}"
  encryption_enabled: {{ pi_encryption_enabled | default(true) }}
