# Home Cyber Risk Awareness Server Configuration
# Copy this file to .env and fill in your values
# Never commit .env to git

# Have I Been Pwned API
# Optional: API key for paid features (email/username breach checking)
# Free Pwned Passwords API works without a key
HIBP_API_KEY=

# Database Configuration
# SQLite default (no setup required)
DATABASE_URL=sqlite:///data/breaches.db
# Optional: Use Postgres instead
# DATABASE_URL=postgresql://breachmon:changeme@postgres:5432/breaches

# Check Cadence
# How often to check for breaches (in hours)
# Default: 168 (weekly)
CHECK_CADENCE=168

# Alert Configuration - Email (SMTP)
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_SMTP_USER=your-email@gmail.com
ALERT_EMAIL_SMTP_PASSWORD=your-app-password
ALERT_EMAIL_FROM=your-email@gmail.com
ALERT_EMAIL_TO=your-email@gmail.com
ALERT_EMAIL_USE_TLS=true

# Alert Configuration - Telegram (Optional)
ALERT_TELEGRAM_ENABLED=false
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# Alert Configuration - Webhook (Optional)
ALERT_WEBHOOK_ENABLED=false
ALERT_WEBHOOK_URL=http://localhost:8080/webhook

# Logging
LOG_LEVEL=INFO
# Loki endpoint for log aggregation (optional)
LOKI_URL=http://loki:3100/loki/api/v1/push

# Grafana Configuration (for observability)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Pi-hole Configuration (optional)
PIHOLE_ENABLED=false
PIHOLE_PASSWORD=changeme

# PostgreSQL Configuration (if using Postgres)
POSTGRES_PASSWORD=changeme
