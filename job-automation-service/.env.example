# Job Automation Service - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Database Configuration
DATABASE_URL=postgresql://jobautomation:password@localhost:5433/jobautomation

# API Keys for Job Sources
ADZUNA_API_ID=your-adzuna-api-id-here
ADZUNA_API_KEY=your-adzuna-api-key-here
JSEARCH_API_KEY=your-jsearch-api-key-here

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Application Settings
SECRET_KEY=change-me-in-production-use-secrets-token-urlsafe-32-chars
DEBUG=false

# Default Search Parameters
DEFAULT_LOCATION=Minneapolis, MN
