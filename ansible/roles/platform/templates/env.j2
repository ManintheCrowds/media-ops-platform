# Platform Environment Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

# Application Secrets
SECRET_KEY={{ platform_secret_key }}
JWT_SECRET_KEY={{ platform_jwt_secret_key }}

# Database
DATABASE_URL=postgresql://{{ postgres_user }}:{{ postgres_password }}@postgres:5432/{{ postgres_database }}

# Service URLs
SEAFILE_URL={{ seafile_url | default('http://seafile:8000') }}
JELLYFIN_URL={{ jellyfin_url | default('http://jellyfin:8096') }}
GITEA_URL={{ gitea_url | default('http://gitea:3000') }}
PROMETHEUS_URL={{ prometheus_url | default('http://prometheus:9090') }}
GRAFANA_URL={{ grafana_url | default('http://grafana:3000') }}
VAULTWARDEN_URL={{ vaultwarden_url | default('http://vaultwarden:80') }}

# Service API Tokens
SEAFILE_API_TOKEN={{ seafile_api_token | default('') }}
JELLYFIN_API_KEY={{ jellyfin_api_key | default('') }}
GITEA_API_TOKEN={{ gitea_api_token | default('') }}
VAULTWARDEN_ADMIN_TOKEN={{ vaultwarden_admin_token | default('') }}
BOOKSTACK_APP_KEY={{ bookstack_app_key | default('') }}
BOOKSTACK_DB_PASSWORD={{ bookstack_db_password | default('') }}

# CORS Configuration
CORS_ORIGINS={{ cors_origins | default('["http://localhost"]') }}
CORS_ALLOW_CREDENTIALS={{ cors_allow_credentials | default('true') }}

# Debug Mode
DEBUG={{ debug_mode | default('False') }}
