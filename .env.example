# Application Settings
APP_NAME=Self-Hosted Platform
DEBUG=True
SECRET_KEY=change-me-in-production-secret-key

# Database (dev defaults match docker-compose ${POSTGRES_PASSWORD:-changeme})
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://platform:changeme@postgres:5432/platform

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# Service URLs (optional - configure as needed)
SEAFILE_URL=http://seafile:8000
SEAFILE_API_TOKEN=
SEAFILE_ADMIN_PASSWORD=changeme
SEAFILE_DB_ROOT_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=changeme

JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=

GITEA_URL=http://gitea:3000
GITEA_API_TOKEN=

PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=admin
GRAFANA_ADMIN_PASSWORD=admin

VAULTWARDEN_URL=http://vaultwarden:80
VAULTWARDEN_ADMIN_TOKEN=

# Security service (set in .env only — never commit real keys)
SECURITY_VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# Optional per-service DB passwords (docker-compose dev defaults)
GITEA_POSTGRES_PASSWORD=changeme
EDUCATION_POSTGRES_PASSWORD=changeme
JOB_AUTOMATION_POSTGRES_PASSWORD=changeme

# CORS Settings
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
