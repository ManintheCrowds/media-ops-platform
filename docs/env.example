# Security Service Configuration
# Copy these to your .env file and fill in your values

# Breach Detection Configuration (Free - using HIBP Pwned Passwords API and public sources)
# Password checking uses free HIBP Pwned Passwords API (no API key required)
# Email/domain checking uses free public breach sources

# Feature Flags
SECURITY_HIBP_ENABLE_PASSWORD_CHECK=true  # Uses free HIBP Pwned Passwords API
SECURITY_HIBP_ENABLE_EMAIL_CHECK=true  # Uses free public breach sources

# Cache and Rate Limiting
SECURITY_HIBP_CACHE_TTL=3600  # 1 hour in seconds
SECURITY_HIBP_RATE_LIMIT_DELAY=0.2  # 200ms between requests

# Domain Monitoring (comma-separated list)
SECURITY_BREACH_MONITORED_DOMAINS=example.com,yourcompany.com
SECURITY_HIBP_DOMAIN_CHECK_INTERVAL=86400  # 24 hours in seconds

# Public Breach Sources (comma-separated URLs)
# Supported formats: GitHub raw URLs, JSON endpoints, CSV files, text files (one email per line)
# 
# Format requirements:
#   JSON: {"breaches": [{"email": "...", "breach_name": "...", "breach_date": "..."}]}
#   CSV: email,breach_name,breach_date
#   Text: One email address per line
#
# Examples:
# SECURITY_PUBLIC_BREACH_SOURCES=https://raw.githubusercontent.com/user/repo/breaches.json,https://example.com/breach-list.csv
#
# Note: Research and add reputable public breach data sources. The system will download
#       and parse data from these sources on-demand via the /api/security/breaches/update-database endpoint.
SECURITY_PUBLIC_BREACH_SOURCES=

# Breach Database Update Configuration
SECURITY_BREACH_DATA_UPDATE_INTERVAL=86400  # 24 hours in seconds
SECURITY_BREACH_DATA_CACHE_DIR=/var/cache/breach-data  # Local cache directory

# Other Security Service Configuration
SECURITY_ABUSEIPDB_API_KEY=your-abuseipdb-key
SECURITY_VIRUSTOTAL_API_KEY=your-virustotal-key

# Alerting Configuration
SECURITY_ALERT_EMAIL_ENABLED=false
SECURITY_ALERT_EMAIL_SMTP_HOST=smtp.example.com
SECURITY_ALERT_EMAIL_SMTP_PORT=587
SECURITY_ALERT_EMAIL_SMTP_USER=your-smtp-user
SECURITY_ALERT_EMAIL_SMTP_PASSWORD=your-smtp-password
SECURITY_ALERT_EMAIL_FROM=alerts@example.com
SECURITY_ALERT_EMAIL_TO=security@example.com

# Database Configuration
SECURITY_DATABASE_URL=postgresql://platform:platform@postgres:5432/platform

# Redis Configuration
SECURITY_REDIS_URL=redis://redis:6379

