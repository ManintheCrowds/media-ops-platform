# Application Settings
APP_NAME=Self-Hosted Platform
DEBUG=True
SECRET_KEY=change-me-in-production-secret-key

# Database
DATABASE_URL=postgresql://platform:platform@postgres:5432/platform

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# Service URLs (optional - configure as needed)
SEAFILE_URL=http://seafile:8000
SEAFILE_API_TOKEN=

JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=

GITEA_URL=http://gitea:3000
GITEA_API_TOKEN=

PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=admin

VAULTWARDEN_URL=http://vaultwarden:80
VAULTWARDEN_ADMIN_TOKEN=

# CORS Settings
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
