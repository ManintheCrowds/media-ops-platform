{
  "dashboard": {
    "title": "Harness DAGGR Metrics",
    "tags": ["daggr", "harness", "workflows", "scp", "blue_hat"],
    "timezone": "browser",
    "schemaVersion": 27,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Workflow runs by status",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "increase(daggr_workflow_runs_total{project=\"harness\"}[5m])",
            "legendFormat": "{{workflow}} {{status}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {"drawStyle": "line", "fillOpacity": 10}
          }
        }
      },
      {
        "id": 2,
        "title": "Workflow run duration (seconds)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.5, sum(rate(daggr_workflow_duration_seconds_bucket{project=\"harness\"}[5m])) by (le, workflow))",
            "legendFormat": "p50 {{workflow}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(daggr_workflow_duration_seconds_bucket{project=\"harness\"}[5m])) by (le, workflow))",
            "legendFormat": "p95 {{workflow}}",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {"drawStyle": "line", "fillOpacity": 10}
          }
        }
      },
      {
        "id": 3,
        "title": "Total workflow runs (workflow/status)",
        "type": "table",
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "daggr_workflow_runs_total{project=\"harness\"}",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ]
      }
    ]
  }
}
